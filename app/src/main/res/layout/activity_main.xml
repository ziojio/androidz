<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidz.widget.TitleBar
        android:id="@+id/titlebar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:leftVisible="false"
        app:lineVisible="true"
        app:title="AndroidZ" />

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/dp_20"
        app:dividerDrawable="@drawable/divider_space_20dp"
        app:flexWrap="wrap"
        app:showDivider="middle">

        <Button
            android:id="@+id/execFunction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="execFunction" />

        <Button
            android:id="@+id/showFunction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="showFunction" />

        <Button
            android:id="@+id/openDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="openDialog" />

        <Button
            android:id="@+id/openUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="openUrl" />

        <Button
            android:id="@+id/network"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="network" />
    </com.google.android.flexbox.FlexboxLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dp_8"
        android:text="listview" />

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:choiceMode="multipleChoice"
        android:divider="@drawable/divider_line" />

</LinearLayout>